# Base de datos
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/toori360

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_REFRESH_EXPIRATION=7d

# Supabase Storage
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=toori360-attachments

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@tudominio.com

# OpenAI (para clasificación WhatsApp)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# WhatsApp Business API
WHATSAPP_VERIFY_TOKEN=change-me-random-string

# URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORTAL_URL=http://localhost:3002

# Entorno
NODE_ENV=development
PORT=3001
