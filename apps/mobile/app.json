{
  "expo": {
    "name": "Toori360",
    "slug": "toori360",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "toori360",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nativosd.toori360"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nativosd.toori360"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "Toori360 necesita acceso a la cámara para fotografiar el trabajo" }
      ],
      [
        "expo-location",
        { "locationWhenInUsePermission": "Toori360 necesita tu ubicación para registrar check-in" }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
