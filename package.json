{
  "name": "toori360",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "dev:mobile": "turbo run dev --filter=mobile",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "build:api": "turbo run build --filter=api...",
    "test": "turbo run test",
    "test:api": "turbo run test --filter=api",
    "test:web": "turbo run test --filter=web",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "turbo run typecheck",
    "db:migrate": "turbo run db:migrate --filter=@toori360/db",
    "db:seed": "turbo run db:seed --filter=@toori360/db",
    "db:studio": "turbo run db:studio --filter=@toori360/db",
    "db:generate": "turbo run db:generate --filter=@toori360/db",
    "db:reset": "turbo run db:reset --filter=@toori360/db"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.9.0",
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.5",
      "@types/react-dom": "^18.3.0"
    }
  }
}
