generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========== TENANT ==========
model Tenant {
  id                  String      @id @default(uuid()) @db.Uuid
  name                String
  slug                String      @unique
  plan                Plan        @default(FREE)
  settings            Json        @default("{}")
  logoUrl             String?
  status              TenantStatus @default(ACTIVE)
  onboardingCompleted Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  users      User[]
  properties Property[]
  providers  Provider[]
  trades     Trade[]
  tickets    Ticket[]
  slaConfigs SlaConfig[]
  categories Category[]
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

// ========== USER ==========
model User {
  id                String     @id @default(uuid()) @db.Uuid
  tenantId          String     @db.Uuid
  email             String
  phone             String?
  name              String
  role              UserRole
  avatarUrl         String?
  status            UserStatus @default(ACTIVE)
  supabaseAuthId    String?    @unique
  passwordHash      String?
  lastLogin         DateTime?
  notificationPrefs Json       @default("{}")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  ticketsCreated  Ticket[]      @relation("TicketRequester")
  ticketsAssigned Ticket[]      @relation("TicketAssignee")
  events          TicketEvent[]
  ratings         Rating[]

  @@unique([tenantId, email])
  @@index([tenantId, role])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  SUPERVISOR
  REQUESTER
  PROVIDER_USER
  AUDITOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

// ========== PROPERTY ==========
model Property {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  name      String
  address   String
  lat       Float?
  lng       Float?
  type      PropertyType
  parentId  String?      @db.Uuid
  photoUrl  String?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Property?  @relation("PropertyHierarchy", fields: [parentId], references: [id])
  children Property[] @relation("PropertyHierarchy")
  units    Unit[]
  tickets  Ticket[]
  assets   Asset[]

  @@index([tenantId])
}

enum PropertyType {
  BUILDING
  HOUSE
  COMPLEX
  OFFICE
  COMMERCIAL
}

// ========== UNIT ==========
model Unit {
  id           String   @id @default(uuid()) @db.Uuid
  propertyId   String   @db.Uuid
  identifier   String
  floor        String?
  type         UnitType
  contactName  String?
  contactPhone String?
  contactEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  tickets  Ticket[]
  assets   Asset[]

  @@unique([propertyId, identifier])
}

enum UnitType {
  APARTMENT
  LOCAL
  COMMON_AREA
  PARKING
  STORAGE
  OFFICE
}

// ========== ASSET ==========
model Asset {
  id          String      @id @default(uuid()) @db.Uuid
  propertyId  String?     @db.Uuid
  unitId      String?     @db.Uuid
  name        String
  type        String
  brand       String?
  model       String?
  status      AssetStatus @default(ACTIVE)
  installDate DateTime?
  warrantyEnd DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  property Property? @relation(fields: [propertyId], references: [id])
  unit     Unit?     @relation(fields: [unitId], references: [id])
  tickets  Ticket[]
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  DECOMMISSIONED
}

// ========== PROVIDER ==========
model Provider {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @db.Uuid
  businessName    String
  cuit            String?
  contactName     String
  phone           String
  email           String?
  address         String?
  status          ProviderStatus @default(PENDING)
  avgRating       Float          @default(0)
  avgResponseTime Int?
  totalJobs       Int            @default(0)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  trades  ProviderTrade[]
  quotes  Quote[]
  visits  Visit[]
  tickets Ticket[]
  ratings Rating[]

  @@index([tenantId, status])
}

enum ProviderStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

model ProviderTrade {
  id             String   @id @default(uuid()) @db.Uuid
  providerId     String   @db.Uuid
  tradeId        String   @db.Uuid
  coverageZones  Json     @default("[]")
  hourlyRate     Float?
  availableHours Json     @default("{}")
  createdAt      DateTime @default(now())

  provider Provider @relation(fields: [providerId], references: [id])
  trade    Trade    @relation(fields: [tradeId], references: [id])

  @@unique([providerId, tradeId])
}

// ========== TRADE (RUBRO) ==========
model Trade {
  id       String   @id @default(uuid()) @db.Uuid
  tenantId String   @db.Uuid
  name     String
  icon     String?
  parentId String?  @db.Uuid
  createdAt DateTime @default(now())

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  parent    Trade?          @relation("TradeHierarchy", fields: [parentId], references: [id])
  children  Trade[]         @relation("TradeHierarchy")
  providers ProviderTrade[]
  tickets   Ticket[]

  @@index([tenantId])
}

// ========== CATEGORY ==========
model Category {
  id       String   @id @default(uuid()) @db.Uuid
  tenantId String   @db.Uuid
  name     String
  icon     String?
  parentId String?  @db.Uuid
  createdAt DateTime @default(now())

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  tickets  Ticket[]

  @@index([tenantId])
}

// ========== TICKET ==========
model Ticket {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @db.Uuid
  number      String
  title       String
  description String
  status      TicketStatus @default(NEW)
  priority    Priority     @default(MEDIUM)
  categoryId  String?      @db.Uuid
  tradeId     String?      @db.Uuid
  propertyId  String       @db.Uuid
  unitId      String?      @db.Uuid
  assetId     String?      @db.Uuid
  requesterId String       @db.Uuid
  assigneeId  String?      @db.Uuid
  providerId  String?      @db.Uuid
  slaConfigId String?      @db.Uuid
  slaDueAt      DateTime?
  slaAlertSent  Boolean  @default(false)
  source        TicketSource @default(WEB)
  tags        String[]     @default([])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  closedAt    DateTime?

  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  category  Category?    @relation(fields: [categoryId], references: [id])
  trade     Trade?       @relation(fields: [tradeId], references: [id])
  property  Property     @relation(fields: [propertyId], references: [id])
  unit      Unit?        @relation(fields: [unitId], references: [id])
  asset     Asset?       @relation(fields: [assetId], references: [id])
  requester User         @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee  User?        @relation("TicketAssignee", fields: [assigneeId], references: [id])
  provider  Provider?    @relation(fields: [providerId], references: [id])
  slaConfig SlaConfig?   @relation(fields: [slaConfigId], references: [id])
  events      TicketEvent[]
  quotes      Quote[]
  visits      Visit[]
  attachments Attachment[]
  ratings     Rating[]
  checklists  Checklist[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, propertyId])
  @@index([tenantId, providerId])
  @@index([tenantId, priority, status])
  @@index([slaDueAt])
}

enum TicketStatus {
  NEW
  RECEIVED
  IN_REVIEW
  ASSIGNED
  AWAITING_QUOTE
  QUOTE_RECEIVED
  PENDING_APPROVAL
  APPROVED
  SCHEDULING_VISIT
  IN_PROGRESS
  PAUSED
  COMPLETED
  VALIDATED
  CLOSED
  CANCELLED
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TicketSource {
  WEB
  APP
  WHATSAPP
  EMAIL
  MANUAL
}

// ========== TICKET EVENT ==========
model TicketEvent {
  id         String     @id @default(uuid()) @db.Uuid
  ticketId   String     @db.Uuid
  userId     String?    @db.Uuid
  eventType  EventType
  data       Json       @default("{}")
  visibility Visibility @default(INTERNAL)
  createdAt  DateTime   @default(now())

  ticket      Ticket       @relation(fields: [ticketId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  attachments Attachment[]

  @@index([ticketId, createdAt])
}

enum EventType {
  STATUS_CHANGE
  MESSAGE
  FILE_UPLOAD
  QUOTE_SENT
  QUOTE_APPROVED
  QUOTE_REJECTED
  VISIT_SCHEDULED
  VISIT_CONFIRMED
  VISIT_RESCHEDULED
  VISIT_CANCELLED
  CHECKIN
  CHECKOUT
  EVIDENCE_UPLOADED
  ASSIGNMENT
  PRIORITY_CHANGE
  SLA_ALERT
  NOTE
  SYSTEM
}

enum Visibility {
  INTERNAL
  PROVIDER
  CLIENT
  ALL
}

// ========== QUOTE ==========
model Quote {
  id              String      @id @default(uuid()) @db.Uuid
  ticketId        String      @db.Uuid
  providerId      String      @db.Uuid
  amount          Float
  currency        String      @default("ARS")
  description     String
  estimatedDays   Int?
  conditions      String?
  status          QuoteStatus @default(PENDING)
  approvedBy      String?     @db.Uuid
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  ticket   Ticket   @relation(fields: [ticketId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@index([ticketId, status])
}

enum QuoteStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// ========== VISIT ==========
model Visit {
  id               String      @id @default(uuid()) @db.Uuid
  ticketId         String      @db.Uuid
  providerId       String      @db.Uuid
  scheduledAt      DateTime
  windowStart      String?
  windowEnd        String?
  status           VisitStatus @default(SCHEDULED)
  checkinAt        DateTime?
  checkoutAt       DateTime?
  checkinLat       Float?
  checkinLng       Float?
  notes            String?
  rescheduleReason String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  ticket   Ticket   @relation(fields: [ticketId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@index([providerId, scheduledAt])
  @@index([ticketId])
}

enum VisitStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  RESCHEDULED
}

// ========== ATTACHMENT ==========
model Attachment {
  id         String             @id @default(uuid()) @db.Uuid
  ticketId   String             @db.Uuid
  eventId    String?            @db.Uuid
  fileUrl    String
  fileType   String
  fileName   String
  fileSize   Int
  category   AttachmentCategory @default(DOCUMENT)
  uploadedBy String             @db.Uuid
  createdAt  DateTime           @default(now())

  ticket Ticket       @relation(fields: [ticketId], references: [id])
  event  TicketEvent? @relation(fields: [eventId], references: [id])
}

enum AttachmentCategory {
  BEFORE
  AFTER
  QUOTE_DOC
  DOCUMENT
  EVIDENCE
  OTHER
}

// ========== SLA CONFIG ==========
model SlaConfig {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @db.Uuid
  priority            Priority
  responseTimeHours   Int
  resolutionTimeHours Int
  escalationRules     Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  tickets Ticket[]

  @@unique([tenantId, priority])
}

// ========== RATING ==========
model Rating {
  id         String   @id @default(uuid()) @db.Uuid
  ticketId   String   @db.Uuid
  providerId String   @db.Uuid
  ratedBy    String   @db.Uuid
  score      Int
  comment    String?
  createdAt  DateTime @default(now())

  ticket   Ticket   @relation(fields: [ticketId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])
  rater    User     @relation(fields: [ratedBy], references: [id])

  @@unique([ticketId, ratedBy])
}

// ========== CHECKLIST ==========
model Checklist {
  id          String    @id @default(uuid()) @db.Uuid
  ticketId    String    @db.Uuid
  name        String
  items       Json
  completedAt DateTime?
  completedBy String?   @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id])
}

// ========== NOTIFICATION ==========
model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  tenantId  String              @db.Uuid
  userId    String              @db.Uuid
  ticketId  String?             @db.Uuid
  channel   NotificationChannel
  type      String
  title     String
  body      String
  data      Json                @default("{}")
  status    NotificationStatus  @default(PENDING)
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId, status, createdAt])
}

enum NotificationChannel {
  PUSH
  EMAIL
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

// ========== TICKET SEQUENCE (para numeración) ==========
model TicketSequence {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @unique @db.Uuid
  yearMonth String // "202604"
  sequence Int    @default(0)
}
