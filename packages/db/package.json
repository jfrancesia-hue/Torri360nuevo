    "db:reset": "prisma migrate reset --force && ts-node src/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "@toori360/shared": "workspace:*",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "prisma": "^5.19.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "@types/bcryptjs": "^2.4.6"
  }
}
