# Database
DATABASE_URL=postgresql://postgres:xxx@db.xxx.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:xxx@db.xxx.supabase.co:5432/postgres

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# JWT
JWT_SECRET=change_me_in_production_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_in_production_min_32_chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# API
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
API_PORT=3001

# WhatsApp
WHATSAPP_VERIFY_TOKEN=xxx
WHATSAPP_ACCESS_TOKEN=xxx
WHATSAPP_PHONE_NUMBER_ID=xxx

# OpenAI
OPENAI_API_KEY=xxx

# Supabase Storage
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx
SUPABASE_BUCKET=toori360-attachments

# Email (Resend)
RESEND_API_KEY=xxx
RESEND_FROM_EMAIL=noreply@toori360.com

# Realtime WebSocket
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Firebase
FIREBASE_PROJECT_ID=xxx
FIREBASE_PRIVATE_KEY=xxx
FIREBASE_CLIENT_EMAIL=xxx

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=xxx

# Redis
REDIS_URL=redis://localhost:6379

# Sentry
SENTRY_DSN=xxx

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
